{
  "openapi": "3.0.1",
  "info": {
    "title": "BidNow API",
    "description": "Documentation for BidNow Auction System APIs. \n\nAccess all microservices through the API Gateway. \nAuthentication is handled via JWT Bearer tokens.",
    "contact": {
      "name": "BidNow Support",
      "email": "support@bidnow.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "Categories",
      "description": "Categories of auctions"
    },
    {
      "name": "Auctions",
      "description": "Auction management endpoints to browse and manage auction listings"
    }
  ],
  "paths": {
    "/api/v1/auctions/{id}": {
      "put": {
        "tags": [
          "Auctions"
        ],
        "summary": "Update an auction (only allowed before it starts)",
        "operationId": "updateAuction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAuctionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "description": "Auction cannot be modified",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "200": {
            "description": "Auction updated successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Auction or category not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "403": {
            "description": "Not the auction owner",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Auctions"
        ],
        "summary": "Delete (soft) an auction (only allowed before it starts)",
        "operationId": "deleteAuction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "404": {
            "description": "Auction not found"
          },
          "400": {
            "description": "Auction cannot be deleted"
          },
          "403": {
            "description": "Not the auction owner"
          },
          "204": {
            "description": "Auction deleted successfully"
          }
        }
      }
    },
    "/demo/jobs/schedule": {
      "post": {
        "tags": [
          "job-runr-demo-controller"
        ],
        "operationId": "schedule",
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "Hello from scheduled JobRunr!"
            }
          },
          {
            "name": "seconds",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseString"
                }
              }
            }
          }
        }
      }
    },
    "/demo/jobs/failing": {
      "post": {
        "tags": [
          "job-runr-demo-controller"
        ],
        "operationId": "failing",
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "This will fail!"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseString"
                }
              }
            }
          }
        }
      }
    },
    "/demo/jobs/enqueue": {
      "post": {
        "tags": [
          "job-runr-demo-controller"
        ],
        "operationId": "enqueue",
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "Hello from JobRunr!"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseString"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "summary": "Create a new auction listing",
        "operationId": "createAuction",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuctionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "description": "Validation error or business rule violation",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "201": {
            "description": "Auction created successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Category not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/{id}/publish": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "summary": "Publish a DRAFT auction (transitions to SCHEDULED or ACTIVE)",
        "operationId": "publishAuction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Auction published successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Auction not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Not in DRAFT status or end time is in the past",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          },
          "403": {
            "description": "Not the auction owner",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSellerAuctionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/{id}/cancel": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "summary": "Cancel an auction (DRAFT/SCHEDULED/ACTIVE → CANCELLED)",
        "operationId": "cancelAuction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelAuctionRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Auction cancelled successfully"
          },
          "404": {
            "description": "Auction not found"
          },
          "400": {
            "description": "Auction is in a terminal state"
          },
          "403": {
            "description": "Not the auction owner"
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "tags": [
          "Categories"
        ],
        "summary": "Get all active auction categories",
        "operationId": "getCategories",
        "responses": {
          "200": {
            "description": "Category list returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseListAuctionCategoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/public": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "summary": "Browse active auctions with filtering and sorting (public)",
        "operationId": "browseAuctions",
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/PublicAuctionFilterRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Auction list returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponsePageResponseAuctionBrowseItem"
                }
              }
            }
          },
          "400": {
            "description": "Invalid filter parameters",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponsePageResponseAuctionBrowseItem"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/public/{id}": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "summary": "Get auction details by ID (public)",
        "operationId": "getAuctionById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Auction retrieved successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseAuctionDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Auction not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseAuctionDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/public/category-counts": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "summary": "Get active auction count per category (public, cached)",
        "operationId": "getCategoryAuctionCounts",
        "responses": {
          "200": {
            "description": "Category counts returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseListCategoryCountResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/me": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "summary": "List auctions owned by the authenticated seller",
        "operationId": "getMyAuctions",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "active"
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Auction list returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponsePageResponseAuctionSummaryResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateAuctionRequest": {
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "description": "Auction title"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the item"
          },
          "categoryId": {
            "type": "string",
            "description": "Category UUID",
            "format": "uuid"
          },
          "startingPrice": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Initial bidding price",
            "example": 100
          },
          "bidIncrement": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Minimum bid increase amount",
            "example": 10
          },
          "buyNowPrice": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Optional instant purchase price (null to remove)"
          },
          "depositAmount": {
            "minimum": 0,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Required deposit to participate",
            "example": 50
          },
          "startTime": {
            "type": "string",
            "description": "Auction start datetime (UTC)",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "description": "Auction end datetime (UTC)",
            "format": "date-time"
          },
          "imageUrls": {
            "maxItems": 10,
            "minItems": 1,
            "type": "array",
            "description": "Replacement image URL list (1–10); omit to keep existing images",
            "items": {
              "type": "string",
              "description": "Replacement image URL list (1–10); omit to keep existing images"
            }
          }
        },
        "description": "Request to update an existing auction (all fields optional — null values are ignored)"
      },
      "AuctionCategoryResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Category UUID",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "Category name",
            "example": "Electronics"
          },
          "slug": {
            "type": "string",
            "description": "URL-friendly slug",
            "example": "electronics"
          }
        },
        "description": "Auction category summary"
      },
      "AuctionImageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Image UUID",
            "format": "uuid"
          },
          "imageUrl": {
            "type": "string",
            "description": "Full image URL"
          },
          "thumbnailUrl": {
            "type": "string",
            "description": "Thumbnail URL"
          },
          "displayOrder": {
            "type": "integer",
            "description": "Display order in gallery",
            "format": "int32"
          },
          "isPrimary": {
            "type": "boolean",
            "description": "Whether this is the primary/cover image"
          },
          "uploadedAt": {
            "type": "string",
            "description": "Upload timestamp",
            "format": "date-time"
          }
        },
        "description": "Auction image details"
      },
      "BaseResponseSellerAuctionResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the response",
            "format": "date-time",
            "example": "2024-03-20T10:00:00Z"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "format": "int32",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "Response message",
            "example": "Success"
          },
          "data": {
            "$ref": "#/components/schemas/SellerAuctionResponse"
          }
        },
        "description": "Generic API response wrapper"
      },
      "SellerAuctionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Auction UUID",
            "format": "uuid"
          },
          "sellerId": {
            "type": "string",
            "description": "Seller user ID",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "description": "Auction title"
          },
          "description": {
            "type": "string",
            "description": "Item description"
          },
          "category": {
            "$ref": "#/components/schemas/AuctionCategoryResponse"
          },
          "startingPrice": {
            "type": "number",
            "description": "Initial bidding price"
          },
          "bidIncrement": {
            "type": "number",
            "description": "Minimum bid increase amount"
          },
          "buyNowPrice": {
            "type": "number",
            "description": "Optional instant purchase price"
          },
          "depositAmount": {
            "type": "number",
            "description": "Required deposit to participate"
          },
          "currentPrice": {
            "type": "number",
            "description": "Current highest bid amount"
          },
          "currentWinnerId": {
            "type": "string",
            "description": "User ID of current highest bidder",
            "format": "uuid"
          },
          "totalBids": {
            "type": "integer",
            "description": "Total number of bids placed",
            "format": "int32"
          },
          "status": {
            "type": "string",
            "description": "Auction status",
            "enum": [
              "DRAFT",
              "SCHEDULED",
              "ACTIVE",
              "COMPLETED",
              "FAILED",
              "CANCELLED"
            ]
          },
          "startTime": {
            "type": "string",
            "description": "Auction start datetime",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "description": "Auction end datetime (may be extended)",
            "format": "date-time"
          },
          "originalEndTime": {
            "type": "string",
            "description": "Original planned end time",
            "format": "date-time"
          },
          "extensionCount": {
            "type": "integer",
            "description": "Number of anti-sniping extensions",
            "format": "int32"
          },
          "completedAt": {
            "type": "string",
            "description": "Actual completion timestamp",
            "format": "date-time"
          },
          "winnerId": {
            "type": "string",
            "description": "Final winner user ID",
            "format": "uuid"
          },
          "images": {
            "type": "array",
            "description": "Auction images",
            "items": {
              "$ref": "#/components/schemas/AuctionImageResponse"
            }
          },
          "createdAt": {
            "type": "string",
            "description": "Record creation timestamp",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "description": "Last update timestamp",
            "format": "date-time"
          }
        },
        "description": "Full auction details returned to the authenticated seller after write operations"
      },
      "BaseResponseString": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the response",
            "format": "date-time",
            "example": "2024-03-20T10:00:00Z"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "format": "int32",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "Response message",
            "example": "Success"
          },
          "data": {
            "type": "string",
            "description": "Response data"
          }
        },
        "description": "Generic API response wrapper"
      },
      "CreateAuctionRequest": {
        "required": [
          "bidIncrement",
          "categoryId",
          "depositAmount",
          "description",
          "endTime",
          "imageUrls",
          "startTime",
          "startingPrice",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "description": "Auction title",
            "example": "Vintage Watch Collection"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the item"
          },
          "categoryId": {
            "type": "string",
            "description": "Category UUID",
            "format": "uuid"
          },
          "startingPrice": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Initial bidding price",
            "example": 100
          },
          "bidIncrement": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Minimum bid increase amount",
            "example": 10
          },
          "buyNowPrice": {
            "minimum": 0.01,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Optional instant purchase price",
            "example": 500
          },
          "depositAmount": {
            "minimum": 0,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "Required deposit to participate",
            "example": 50
          },
          "startTime": {
            "type": "string",
            "description": "Auction start datetime (UTC)",
            "format": "date-time",
            "example": "2026-06-01T10:00:00Z"
          },
          "endTime": {
            "type": "string",
            "description": "Auction end datetime (UTC)",
            "format": "date-time",
            "example": "2026-06-08T10:00:00Z"
          },
          "imageUrls": {
            "maxItems": 10,
            "minItems": 1,
            "type": "array",
            "description": "List of image URLs (1–10)",
            "items": {
              "type": "string",
              "description": "List of image URLs (1–10)"
            }
          },
          "status": {
            "type": "string",
            "description": "Initial status: DRAFT (default) or ACTIVE",
            "example": "DRAFT",
            "enum": [
              "DRAFT",
              "SCHEDULED",
              "ACTIVE",
              "COMPLETED",
              "FAILED",
              "CANCELLED"
            ]
          }
        },
        "description": "Request to create a new auction listing"
      },
      "CancelAuctionRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "BaseResponseListAuctionCategoryResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the response",
            "format": "date-time",
            "example": "2024-03-20T10:00:00Z"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "format": "int32",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "Response message",
            "example": "Success"
          },
          "data": {
            "type": "array",
            "description": "Response data",
            "items": {
              "$ref": "#/components/schemas/AuctionCategoryResponse"
            }
          }
        },
        "description": "Generic API response wrapper"
      },
      "PublicAuctionFilterRequest": {
        "type": "object",
        "properties": {
