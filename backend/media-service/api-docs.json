    "/api/v1/media/presigned-url": {
      "get": {
        "tags": [
          "Media"
        ],
        "summary": "Generate a presigned upload URL (client-side direct upload)",
        "description": "Returns a short-lived S3 presigned PUT URL. The client uploads the file directly to S3 using this URL — the file never passes through the media-service server. URL is valid for 15 minutes.",
        "operationId": "getPresignedUploadUrl",
        "parameters": [
          {
            "name": "fileName",
            "in": "query",
            "description": "Original file name (used to derive the S3 extension)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contentType",
            "in": "query",
            "description": "MIME type of the file, e.g. image/png",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Presigned URL generated",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PresignedUrlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Unsupported content type",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponsePresignedUrlResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponsePresignedUrlResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/media/download": {
      "get": {
        "tags": [
          "Media"
        ],
        "summary": "Get a presigned download URL",
        "description": "Returns a presigned S3 GET URL (valid 1 hour) for the given S3 key. Use the s3Key returned from the upload endpoint.",
        "operationId": "getDownloadUrl",
        "parameters": [
          {
            "name": "s3Key",
            "in": "query",
            "description": "S3 object key returned from upload",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Download URL generated",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseString"
